# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/autocontent?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Server
PORT=3000
NODE_ENV=development

# AI APIs ( placeholders )
OPENAI_API_KEY=
KLING_AI_API_KEY=
TTS_API_KEY=

# Facebook
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_PAGE_TOKEN=

# Extension
EXTENSION_SECRET=your-extension-secret-key
